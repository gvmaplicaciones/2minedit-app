{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "2minedit.com" }],
      "destination": "https://www.2minedit.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!ffmpeg-core|sitemap\\.xml|robots\\.txt|favicon\\.svg|icons\\.svg).*)", "destination": "/index.html" }
  ]
}
